# פיתוח: לאן Vite מפנה את /api (בדרך כלל localhost:3000)
VITE_API_PROXY_TARGET=http://localhost:3000

# פרודקשן (חובה בבילד של האתר הסטטי): כתובת מלאה לשרת ה-API בלי /api בסוף
# (אותו שרת שמריץ Socket.IO לצ'אט)
# VITE_API_BASE_URL=https://YOUR-API.onrender.com

# אופציונלי: אם רוצים לכפות מקור אחר ל-WebSocket בלבד
# VITE_SOCKET_URL=https://YOUR-API.onrender.com

# VITE_ANALYZE_FACE_URL=

# Firebase (client)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
